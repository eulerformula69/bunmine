{
  "name": "bunmine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:captions": "node tools/build-media-captions.mjs",
    "build": "npm run build:captions && tsc -p tsconfig.json",
    "test:highlighter": "npm run build && node tests/highlighter-match-tests.mjs",
    "test:subtitles": "npm run build && node tests/subtitle-model-tests.mjs && node tests/subtitle-provider-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "esbuild": "0.25.6",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "media-captions": "0.0.18"
  }
}
