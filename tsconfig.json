{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "None",
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "alwaysStrict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "frontend",
    "outDir": "dist"
  },
  "include": [
    "frontend/js/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
